# Comma-separated list of email domains allowed to register.
# Only people with a school email address can create an account.
ALLOWED_EMAIL_DOMAINS=harrowappi.jp

# Comma-separated emails that are automatically given the ADMIN role on signup.
ADMIN_EMAILS=1fabianloke@gmail.com

# Comma-separated emails that are automatically given the STAFF role on signup.
STAFF_EMAILS=

# Where the SQLite database and uploaded files live. Must be a persistent disk.
DATA_DIR=./data

# Set to "1" to hide the map pages entirely (strictest privacy mode —
# route maps request tiles from openstreetmap.org, which reveals rough
# map areas being viewed to that service, though never who viewed them).
DISABLE_MAPS=
